// Qwen3_5CS.compute
// ======================================================================================
// Mixed-precision GPU inference kernels for Qwen3.5 (text-only) FP16.
// Weights packed FP16 in StructuredBuffer<uint> (2 halves per uint).
// Activations / caches / SSM state are FP32.
//
// Architecture-specific kernels:
//   * Full attention (every 4th layer): GQA + attention output gate + partial RoPE
//   * Linear attention (Gated DeltaNet): causal conv1d + delta-rule recurrence + gated norm
// ======================================================================================

// ================================ PARAMETERS ================================
uint seq_len;
uint hidden_size;
uint head_dim;
uint num_heads_q;
uint num_heads_kv;
uint vocab_size;
uint position_offset;
uint cache_len;
uint cache_capacity;
uint buffer_size;
uint num_vectors;
uint rope_num_heads;
uint rope_rot_dim;          // partial RoPE rot_dim (= head_dim * partial_rotary_factor)
uint seq_len_q;
uint seq_len_k;
uint copy_src_offset;
uint embedding_dim;
uint inner_embedding_dim;
uint intermediate_size;
uint sequence_length_q;
uint sequence_length_k;
uint sequence_length_v;
uint batch_size;

// Linear-attention dims
uint linear_conv_dim;
uint linear_conv_kernel;
uint linear_key_dim;
uint linear_value_dim;
uint linear_num_v_heads;
uint linear_head_k_dim;
uint linear_head_v_dim;

float norm_eps;
float scale;
float temperature;
int top_k_val;
float top_p_val;
float min_p_val;
int rng_seed;
float presence_penalty;     // OpenAI/vLLM-style, subtractive; fires once per already-generated token
float repetition_penalty;   // CTRL/HF-style multiplicative; 1.0 = disabled
int activation_type;        // 0 silu, 1 gelu


// ================================ FP16 WEIGHT HELPER ================================
float readH(StructuredBuffer<uint> buf, uint index)
{
    uint word = buf[index >> 1];
    uint shift = (index & 1u) * 16u;
    return f16tof32(word >> shift);
}


// ================================ BUFFERS ================================
// Tied embed/lm_head + final norm
StructuredBuffer<uint>      embed_weights;
StructuredBuffer<uint>      lm_weights;
StructuredBuffer<uint>      norm_gamma;

// Full-attention layer weights
StructuredBuffer<uint>      W_Q;          // [num_heads_q*head_dim*2, hidden]
StructuredBuffer<uint>      W_K;
StructuredBuffer<uint>      W_V;
StructuredBuffer<uint>      W_O;

// Linear-attention layer weights
StructuredBuffer<uint>      W_inProjQKV;  // [conv_dim = key_dim*2 + value_dim, hidden]
StructuredBuffer<uint>      W_inProjZ;    // [value_dim, hidden]
StructuredBuffer<uint>      W_inProjA;    // [num_v_heads, hidden]
StructuredBuffer<uint>      W_inProjB;    // [num_v_heads, hidden]
StructuredBuffer<uint>      conv_weight;  // [conv_dim, kernel_size] depthwise
StructuredBuffer<uint>      dt_bias;      // [num_v_heads]
StructuredBuffer<uint>      A_log;        // [num_v_heads]
StructuredBuffer<uint>      W_outProj;    // [hidden, value_dim]

// MLP
StructuredBuffer<uint>      mlp_gate_w;   // [intermediate, hidden]
StructuredBuffer<uint>      mlp_up_w;
StructuredBuffer<uint>      mlp_down_w;   // [hidden, intermediate]

// RoPE
StructuredBuffer<uint>      rope_cos;     // packed FP16, [maxSeq, rot_dim/2]
StructuredBuffer<uint>      rope_sin;

// FP32 activations
StructuredBuffer<uint>      token_ids;
RWStructuredBuffer<float>   embed_output;
RWStructuredBuffer<float>   norm_output;
StructuredBuffer<float>     norm_input;

StructuredBuffer<float>     X;
RWStructuredBuffer<float>   Q_out;
RWStructuredBuffer<float>   K_out;
RWStructuredBuffer<float>   V_out;
RWStructuredBuffer<float>   gate_out;     // attention output gate (sigmoid input)

RWStructuredBuffer<float>   rope_buf;

RWStructuredBuffer<float>   kv_cache;
StructuredBuffer<float>     kv_new;

StructuredBuffer<float>     Q;
StructuredBuffer<float>     K;
StructuredBuffer<float>     V;
RWStructuredBuffer<float>   AttentionWeights;
RWStructuredBuffer<float>   AttendedValues;
RWStructuredBuffer<float>   O;
StructuredBuffer<float>     gate_in;

RWStructuredBuffer<float>   input;
RWStructuredBuffer<float>   intermediate;
StructuredBuffer<float>     mlp_input;
RWStructuredBuffer<float>   mlp_output;

// Linear-attn buffers
RWStructuredBuffer<float>   conv_state;        // [conv_dim * (kernel-1)]
RWStructuredBuffer<float>   recurrent_state;   // [num_v_heads * head_k_dim * head_v_dim]
RWStructuredBuffer<float>   linear_qkv;        // [seq, conv_dim]   in/out for conv
StructuredBuffer<float>     linear_q;          // [seq, num_v_heads, head_k_dim]
StructuredBuffer<float>     linear_k;          // [seq, num_v_heads, head_k_dim]
StructuredBuffer<float>     linear_v;          // [seq, num_v_heads, head_v_dim]
RWStructuredBuffer<float>   linear_q_norm;
RWStructuredBuffer<float>   linear_k_norm;
StructuredBuffer<float>     linear_a;          // [seq, num_v_heads]   read view
StructuredBuffer<float>     linear_b;          // [seq, num_v_heads]   read view
StructuredBuffer<float>     linear_z;          // [seq, value_dim]     read view
RWStructuredBuffer<float>   linear_a_w;        // write alias for InProjA
RWStructuredBuffer<float>   linear_b_w;        // write alias for InProjB
RWStructuredBuffer<float>   linear_z_w;        // write alias for InProjZ
RWStructuredBuffer<float>   linear_y;          // [seq, num_v_heads, head_v_dim]
RWStructuredBuffer<float>   linear_y_norm;     // post RMSNormGated   == [seq, value_dim] flat

StructuredBuffer<float>     lm_input;
RWStructuredBuffer<float>   lm_output;

RWStructuredBuffer<float>   logits_buf;      // RW so penalties can be applied in place pre-sampling
RWStructuredBuffer<float>   probs_buf;
RWStructuredBuffer<uint>    argmax_result;
RWStructuredBuffer<uint>    token_seen;      // [vocab] occurrence counts of already-generated tokens

RWStructuredBuffer<float>   buf_a;
StructuredBuffer<float>     buf_b;


// ================================ HELPERS ================================
float silu(float x)   { return x / (1.0 + exp(-x)); }
float sigmoid(float x){ return 1.0 / (1.0 + exp(-x)); }
float softplus(float x){ return log(1.0 + exp(-abs(x))) + max(x, 0.0); }
float safe_tanh(float x)
{
    float a = abs(x);
    float e = exp(-2.0 * a);
    return sign(x) * ((1.0 - e) / (1.0 + e));
}
float gelu(float x)
{
    return 0.5 * x * (1.0 + safe_tanh(0.7978845608 * (x + 0.044715 * x * x * x)));
}
float runif()
{
    rng_seed ^= 2747636419u;
    rng_seed *= 2654435769u;
    rng_seed ^= rng_seed >> 16;
    rng_seed *= 2654435769u;
    rng_seed ^= rng_seed >> 16;
    rng_seed *= 2654435769u;
    return float(rng_seed) / 4294967295.0 + 0.5;
}


// ========================= EmbeddingLookup ===================================
// Qwen does NOT scale embeddings by sqrt(hidden_size).
#pragma kernel EmbeddingLookup
[numthreads(256, 1, 1)]
void EmbeddingLookup(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    if (idx >= seq_len * hidden_size) return;
    uint pos = idx / hidden_size;
    uint h = idx % hidden_size;
    uint tok = token_ids[pos];
    embed_output[idx] = readH(embed_weights, tok * hidden_size + h);
}


// ========================= RmsNormHidden  (Qwen3.5: x * rms * (1+gamma)) =====
// NB: Qwen3.5 parameterizes RMSNorm as `output * (1.0 + weight)` with weight
// initialized to zeros (see modeling_qwen3_5.py:735 — `Qwen3_5RMSNorm.forward`).
// This is non-standard wrt Llama-style RMSNorm (which is just `weight`).
// Used by input_layernorm / post_attention_layernorm / final norm.
#pragma kernel RmsNormHidden
[numthreads(256, 1, 1)]
void RmsNormHidden(uint3 id : SV_DispatchThreadID)
{
    uint pos = id.x;
    if (pos >= seq_len) return;
    uint base_idx = pos * hidden_size;

    float sum_sq = 0.0;
    for (uint i = 0; i < hidden_size; i++)
    {
        float v = norm_input[base_idx + i];
        sum_sq += v * v;
    }
    float rms = rsqrt(sum_sq / (float)hidden_size + norm_eps);

    for (uint i = 0; i < hidden_size; i++)
        norm_output[base_idx + i] = norm_input[base_idx + i] * rms * (1.0 + readH(norm_gamma, i));
}


// ========================= RmsNormHead  (Qwen3.5: x * rms * (1+gamma)) =======
// Same `(1.0 + weight)` parameterization — used by q_norm / k_norm in full-attn.
#pragma kernel RmsNormHead
[numthreads(256, 1, 1)]
void RmsNormHead(uint3 id : SV_DispatchThreadID)
{
    uint vec = id.x;
    if (vec >= num_vectors) return;
    uint base_idx = vec * head_dim;

    float sum_sq = 0.0;
    for (uint i = 0; i < head_dim; i++)
    {
        float v = norm_input[base_idx + i];
        sum_sq += v * v;
    }
    float rms = rsqrt(sum_sq / (float)head_dim + norm_eps);

    for (uint i = 0; i < head_dim; i++)
        norm_output[base_idx + i] = norm_input[base_idx + i] * rms * (1.0 + readH(norm_gamma, i));
}


// ========================= QProjGated ========================================
// q_proj output is [num_heads_q, head_dim * 2]: first half = Q, second half = gate.
// Splits while computing.
#pragma kernel QProjGated
[numthreads(1, 8, 32)]
void QProjGated(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint p = id.z;   // p in [0, num_heads_q * head_dim * 2)
    uint q_full = num_heads_q * head_dim * 2u;
    if (b >= batch_size || l >= sequence_length_q || p >= q_full) return;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_Q, p * embedding_dim + e);

    // p layout: head h occupies p in [h*head_dim*2, (h+1)*head_dim*2).
    // Within head: [0, head_dim) = Q, [head_dim, head_dim*2) = gate.
    uint h = p / (head_dim * 2u);
    uint dp = p % (head_dim * 2u);
    uint out_pos = (b * sequence_length_q + l) * (num_heads_q * head_dim) + h * head_dim + (dp % head_dim);
    if (dp < head_dim) Q_out[out_pos] = sum;
    else               gate_out[out_pos] = sum;
}


// ========================= KProj / VProj =====================================
#pragma kernel KProj
[numthreads(1, 8, 32)]
void KProj(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint p = id.z;   // p in [0, num_heads_kv * head_dim)
    uint kv_full = num_heads_kv * head_dim;
    if (b >= batch_size || l >= sequence_length_q || p >= kv_full) return;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_K, p * embedding_dim + e);

    K_out[(b * sequence_length_q + l) * kv_full + p] = sum;
}

#pragma kernel VProj
[numthreads(1, 8, 32)]
void VProj(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint p = id.z;
    uint kv_full = num_heads_kv * head_dim;
    if (b >= batch_size || l >= sequence_length_q || p >= kv_full) return;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_V, p * embedding_dim + e);

    V_out[(b * sequence_length_q + l) * kv_full + p] = sum;
}


// ========================= ApplyRopePartial ==================================
// Rotates only the first `rope_rot_dim` of each head's `head_dim` (split-half pattern).
// Dims in [rope_rot_dim, head_dim) are left untouched.
#pragma kernel ApplyRopePartial
[numthreads(128, 1, 1)]
void ApplyRopePartial(uint3 id : SV_DispatchThreadID)
{
    uint hd2 = rope_rot_dim / 2u;
    uint total = seq_len * rope_num_heads * hd2;
    uint idx = id.x;
    if (idx >= total) return;

    uint i = idx % hd2;
    uint tmp = idx / hd2;
    uint h = tmp % rope_num_heads;
    uint l = tmp / rope_num_heads;

    uint base_off = (l * rope_num_heads + h) * head_dim;
    float x1 = rope_buf[base_off + i];
    float x2 = rope_buf[base_off + i + hd2];

    uint abs_pos = position_offset + l;
    float c = readH(rope_cos, abs_pos * hd2 + i);
    float s = readH(rope_sin, abs_pos * hd2 + i);

    rope_buf[base_off + i]       = x1 * c - x2 * s;
    rope_buf[base_off + i + hd2] = x2 * c + x1 * s;
}


// ========================= WriteCacheFull ====================================
#pragma kernel WriteCacheFull
[numthreads(256, 1, 1)]
void WriteCacheFull(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    uint total = seq_len * num_heads_kv * head_dim;
    if (idx >= total) return;
    uint d   = idx % head_dim;
    uint tmp = idx / head_dim;
    uint h   = tmp % num_heads_kv;
    uint l   = tmp / num_heads_kv;
    uint cache_pos = cache_len + l;
    kv_cache[(cache_pos * num_heads_kv + h) * head_dim + d] = kv_new[idx];
}


// ========================= ApplyMaskCausal ===================================
#pragma kernel ApplyMaskCausal
[numthreads(16, 16, 1)]
void ApplyMaskCausal(uint3 id : SV_DispatchThreadID)
{
    uint k_pos = id.x;
    uint row   = id.y;
    if (k_pos >= seq_len_k || row >= num_heads_q * seq_len_q) return;
    uint q_pos = row % seq_len_q;
    uint hq    = row / seq_len_q;
    uint abs_q = (seq_len_k - seq_len_q) + q_pos;

    if (k_pos > abs_q)
        AttentionWeights[(hq * seq_len_q + q_pos) * seq_len_k + k_pos] = -1e10;
}


// ========================= SoftmaxRows =======================================
#pragma kernel SoftmaxRows
[numthreads(256, 1, 1)]
void SoftmaxRows(uint3 id : SV_DispatchThreadID)
{
    uint row = id.x;
    uint num_rows = num_heads_q * seq_len_q;
    if (row >= num_rows) return;
    uint base_idx = row * seq_len_k;

    float max_val = AttentionWeights[base_idx];
    for (uint j = 1; j < seq_len_k; j++)
        max_val = max(max_val, AttentionWeights[base_idx + j]);

    float sum_exp = 0.0;
    for (uint j = 0; j < seq_len_k; j++)
    {
        float e = exp(AttentionWeights[base_idx + j] - max_val);
        AttentionWeights[base_idx + j] = e;
        sum_exp += e;
    }
    float inv_sum = 1.0 / max(sum_exp, 1e-12);
    for (uint j = 0; j < seq_len_k; j++)
        AttentionWeights[base_idx + j] *= inv_sum;
}


// ========================= ComputeAttentionScores ============================
#pragma kernel ComputeAttentionScores
[numthreads(4, 32, 4)]
void ComputeAttentionScores(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= sequence_length_q || id.y >= sequence_length_k) return;
    uint g = id.z;
    if (g >= batch_size * num_heads_q) return;

    uint b  = g / num_heads_q;
    uint hq = g % num_heads_q;
    uint group_size = num_heads_q / num_heads_kv;
    uint hkv = hq / group_size;

    float dot = 0.0;
    uint q_base = (((b * sequence_length_q + id.x) * num_heads_q + hq) * head_dim);
    uint k_base = (((b * sequence_length_k + id.y) * num_heads_kv + hkv) * head_dim);
    for (uint d = 0; d < head_dim; d++)
        dot += Q[q_base + d] * K[k_base + d];

    AttentionWeights[((((b * num_heads_q + hq) * sequence_length_q) + id.x) * sequence_length_k + id.y)] = dot * scale;
}


// ========================= AttendValues ======================================
#pragma kernel AttendValues
[numthreads(64, 4, 4)]
void AttendValues(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= head_dim || id.y >= sequence_length_q) return;
    uint g = id.z;
    if (g >= batch_size * num_heads_q) return;

    uint b  = g / num_heads_q;
    uint hq = g % num_heads_q;
    uint group_size = num_heads_q / num_heads_kv;
    uint hkv = hq / group_size;

    float acc = 0.0;
    for (uint j = 0; j < sequence_length_v; j++)
    {
        float w = AttentionWeights[((((b * num_heads_q + hq) * sequence_length_q) + id.y) * sequence_length_k + j)];
        float vv = V[(((b * sequence_length_k + j) * num_heads_kv + hkv) * head_dim + id.x)];
        acc += w * vv;
    }
    AttendedValues[(((b * sequence_length_q + id.y) * num_heads_q + hq) * head_dim + id.x)] = acc;
}


// ========================= ApplyAttnGate =====================================
// Multiplies attended values by sigmoid(gate) element-wise.
// AttendedValues layout: [batch, seq, num_heads_q, head_dim]
// gate_in layout matches.
#pragma kernel ApplyAttnGate
[numthreads(256, 1, 1)]
void ApplyAttnGate(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    uint total = batch_size * sequence_length_q * num_heads_q * head_dim;
    if (idx >= total) return;
    AttendedValues[idx] *= sigmoid(gate_in[idx]);
}


// ========================= OProj =============================================
#pragma kernel OProj
[numthreads(1, 4, 32)]
void OProj(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint e = id.z;
    if (b >= batch_size || l >= sequence_length_q || e >= embedding_dim) return;

    float sum = 0.0;
    for (uint ie = 0; ie < inner_embedding_dim; ie++)
    {
        uint hq = ie / head_dim;
        uint d  = ie % head_dim;
        sum += AttendedValues[(((b * sequence_length_q + l) * num_heads_q + hq) * head_dim + d)]
             * readH(W_O, e * inner_embedding_dim + ie);
    }
    O[((b * sequence_length_q + l) * embedding_dim + e)] = sum;
}


// ============================================================================
//                      LINEAR-ATTENTION (GATED DELTANET) KERNELS
// ============================================================================

// LinearInProjQKV: matmul X[seq, hidden] * W_inProjQKV^T[conv_dim, hidden] -> [seq, conv_dim]
// (output goes into linear_qkv before causal conv1d)
#pragma kernel LinearInProjQKV
[numthreads(1, 8, 32)]
void LinearInProjQKV(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint p = id.z;
    if (b >= batch_size || l >= sequence_length_q || p >= linear_conv_dim) return;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_inProjQKV, p * embedding_dim + e);

    linear_qkv[(b * sequence_length_q + l) * linear_conv_dim + p] = sum;
}

// LinearInProjZ: X * W_inProjZ^T -> [seq, value_dim]
// Output written to linear_z.
#pragma kernel LinearInProjZ
[numthreads(1, 8, 32)]
void LinearInProjZ(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint p = id.z;
    if (b >= batch_size || l >= sequence_length_q || p >= linear_value_dim) return;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_inProjZ, p * embedding_dim + e);

    linear_z_w[(b * sequence_length_q + l) * linear_value_dim + p] = sum;
}

// LinearInProjA: X * W_inProjA^T -> [seq, num_v_heads]
#pragma kernel LinearInProjA
[numthreads(256, 1, 1)]
void LinearInProjA(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    uint total = batch_size * sequence_length_q * linear_num_v_heads;
    if (idx >= total) return;

    uint h = idx % linear_num_v_heads;
    uint tmp = idx / linear_num_v_heads;
    uint l = tmp % sequence_length_q;
    uint b = tmp / sequence_length_q;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_inProjA, h * embedding_dim + e);

    linear_a_w[idx] = sum;
}

// LinearInProjB: X * W_inProjB^T -> [seq, num_v_heads]
#pragma kernel LinearInProjB
[numthreads(256, 1, 1)]
void LinearInProjB(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    uint total = batch_size * sequence_length_q * linear_num_v_heads;
    if (idx >= total) return;

    uint h = idx % linear_num_v_heads;
    uint tmp = idx / linear_num_v_heads;
    uint l = tmp % sequence_length_q;
    uint b = tmp / sequence_length_q;

    float sum = 0.0;
    uint x_base = ((b * sequence_length_q + l) * embedding_dim);
    for (uint e = 0; e < embedding_dim; e++)
        sum += X[x_base + e] * readH(W_inProjB, h * embedding_dim + e);

    linear_b_w[idx] = sum;
}

// CausalConv1DUpdate: single-token decode update of the depthwise causal conv1d.
// state shape [conv_dim, kernel-1] (most recent kernel-1 inputs; col 0 = oldest).
// In-place: linear_qkv[seq=1, conv_dim] is read as x, written back as silu(conv).
#pragma kernel CausalConv1DUpdate
[numthreads(256, 1, 1)]
void CausalConv1DUpdate(uint3 id : SV_DispatchThreadID)
{
    uint c = id.x;
    if (c >= linear_conv_dim) return;

    uint K = linear_conv_kernel;          // 4
    uint K1 = K - 1u;                     // 3

    float x_now = linear_qkv[c];
    // Build window: state[c, 0..K-2], x_now
    // Conv weight layout: [conv_dim, K]
    float acc = 0.0;
    for (uint t = 0; t < K1; t++)
        acc += conv_state[c * K1 + t] * readH(conv_weight, c * K + t);
    acc += x_now * readH(conv_weight, c * K + K1);
    // Activation
    linear_qkv[c] = silu(acc);

    // Shift state left and append x_now
    for (uint t = 0; t < K1 - 1u; t++)
        conv_state[c * K1 + t] = conv_state[c * K1 + t + 1u];
    conv_state[c * K1 + (K1 - 1u)] = x_now;
}

// CausalConv1DPrefill: prefill (seq_len > 1) sequential per-token causal conv.
// Single-thread per channel, loops over seq_len. Writes silu(conv) back into
// linear_qkv in-place. Updates conv_state to reflect last (K-1) tokens.
#pragma kernel CausalConv1DPrefill
[numthreads(256, 1, 1)]
void CausalConv1DPrefill(uint3 id : SV_DispatchThreadID)
{
    uint c = id.x;
    if (c >= linear_conv_dim) return;

    uint K = linear_conv_kernel;
    uint K1 = K - 1u;

    // Snapshot current state (we'll mutate the buffer as we slide)
    float win[8]; // up to kernel_size; here K=4 so [w0,w1,w2,w3]
    [unroll] for (uint t = 0; t < 8u; t++) win[t] = 0.0;
    for (uint t = 0; t < K1; t++)
        win[t] = conv_state[c * K1 + t];

    for (uint l = 0; l < sequence_length_q; l++)
    {
        uint idx = l * linear_conv_dim + c;
        float x_now = linear_qkv[idx];
        // window = [win[0..K-2], x_now]
        float acc = 0.0;
        for (uint t = 0; t < K1; t++)
            acc += win[t] * readH(conv_weight, c * K + t);
        acc += x_now * readH(conv_weight, c * K + K1);
        linear_qkv[idx] = silu(acc);

        // shift window
        for (uint t = 0; t < K1 - 1u; t++) win[t] = win[t + 1u];
        win[K1 - 1u] = x_now;
    }

    // Persist last (K-1) inputs back to conv_state
    for (uint t = 0; t < K1; t++)
        conv_state[c * K1 + t] = win[t];
}

// SplitConvOutQKV: split linear_qkv [seq, conv_dim] into Q,K,V slices.
// conv_dim = key_dim*2 + value_dim. Q chunk = [0, key_dim), K chunk = [key_dim, 2*key_dim),
// V chunk = [2*key_dim, conv_dim).
// Outputs reshaped to [seq, num_v_heads, head_*_dim].
// (Since num_k_heads == num_v_heads for the 0.8B variant, k and v use the same head count.)
#pragma kernel SplitConvOutQKV
[numthreads(256, 1, 1)]
void SplitConvOutQKV(uint3 id : SV_DispatchThreadID)
{
    uint idx = id.x;
    uint total = sequence_length_q * linear_conv_dim;
    if (idx >= total) return;

    uint l = idx / linear_conv_dim;
    uint p = idx % linear_conv_dim;
    float v = linear_qkv[idx];

    if (p < linear_key_dim)
    {
        // Q
        uint h = p / linear_head_k_dim;
        uint d = p % linear_head_k_dim;
        Q_out[(l * linear_num_v_heads + h) * linear_head_k_dim + d] = v;
    }
    else if (p < 2u * linear_key_dim)
    {
        // K
        uint kp = p - linear_key_dim;
        uint h = kp / linear_head_k_dim;
        uint d = kp % linear_head_k_dim;
        K_out[(l * linear_num_v_heads + h) * linear_head_k_dim + d] = v;
    }
    else
    {
        // V
        uint vp = p - 2u * linear_key_dim;
        uint h = vp / linear_head_v_dim;
        uint d = vp % linear_head_v_dim;
        V_out[(l * linear_num_v_heads + h) * linear_head_v_dim + d] = v;
    }
}

// L2NormPerHead: per-head L2 normalize matching HF's `l2norm(x, eps=1e-6)`.
//   inv_norm = rsqrt((x*x).sum(-1) + 1e-6)
//   y = x * inv_norm * out_scale
// out_scale lets the dispatcher fold the post-norm Q scaling (1/sqrt(head_k_dim))
// into this kernel; pass 1.0 for K.
#pragma kernel L2NormPerHead
[numthreads(256, 1, 1)]
void L2NormPerHead(uint3 id : SV_DispatchThreadID)
{
    uint vec = id.x;
    if (vec >= num_vectors) return;
    uint base_idx = vec * head_dim;

    float sum_sq = 0.0;
    for (uint i = 0; i < head_dim; i++)
    {
        float v = norm_input[base_idx + i];
        sum_sq += v * v;
    }
    float inv = rsqrt(sum_sq + 1e-6) * scale;   // 'scale' uniform reused here as out_scale

    for (uint i = 0; i < head_dim; i++)
        norm_output[base_idx + i] = norm_input[base_idx + i] * inv;
}

// DeltaNetRecurrent: token-by-token recurrent gated delta-rule scan.
// Each thread owns one column d of the state matrix S[head, *, d].
// Dispatch: numthreads(128,1,1), groups (1, num_v_heads, 1).
// Loops internally over seq_len (tokens stay sequential — required by recurrence).
//
// Input: linear_q (post L2 norm), linear_k (post L2 norm), linear_v, linear_a, linear_b
//        recurrent_state (carried across calls)
// Param: dt_bias[h], A_log[h]
// Output: linear_y[seq, num_v_heads, head_v_dim]
#pragma kernel DeltaNetRecurrent
[numthreads(128, 1, 1)]
void DeltaNetRecurrent(uint3 id : SV_DispatchThreadID, uint3 gid : SV_GroupID)
{
    uint d = id.x;                   // head_v_dim index (column of S, output dim)
    uint h = gid.y;                  // head index
    if (d >= linear_head_v_dim) return;
    if (h >= linear_num_v_heads) return;

    uint kdim = linear_head_k_dim;
    uint vdim = linear_head_v_dim;
    uint S_base = h * kdim * vdim;

    // dt-bias / A_log are [num_v_heads]
    float a_log_h = readH(A_log, h);
    float dt_b_h  = readH(dt_bias, h);

    for (uint t = 0; t < sequence_length_q; t++)
    {
        // beta[t,h] = sigmoid(linear_b[t, h])
        float bh_logit = linear_b[t * linear_num_v_heads + h];
        float beta_h = sigmoid(bh_logit);

        // g[t,h] = -exp(A_log_h) * softplus(linear_a[t,h] + dt_bias_h)
        float a_th = linear_a[t * linear_num_v_heads + h];
        float g_h = -exp(a_log_h) * softplus(a_th + dt_b_h);
        float decay = exp(g_h);

        // 1) Decay the entire S column for this d.
        for (uint p = 0; p < kdim; p++)
            recurrent_state[S_base + p * vdim + d] *= decay;

        // 2) v_pred[d] from DECAYED state.
        float v_pred = 0.0;
        for (uint p = 0; p < kdim; p++)
        {
            float kp = linear_k[(t * linear_num_v_heads + h) * kdim + p];
            v_pred += recurrent_state[S_base + p * vdim + d] * kp;
        }

        float v_d = linear_v[(t * linear_num_v_heads + h) * vdim + d];
        float delta_d = (v_d - v_pred) * beta_h;

        // 3) Add outer(k, beta*(v - v_pred)) to S (no extra decay).
        for (uint p = 0; p < kdim; p++)
        {
            float kp = linear_k[(t * linear_num_v_heads + h) * kdim + p];
            recurrent_state[S_base + p * vdim + d] += kp * delta_d;
        }

        // 4) y[t, h, d] = sum_p S[h, p, d] * q[t, h, p]
        // Q is already pre-scaled by 1/sqrt(head_k_dim) in the L2-norm pass,
        // matching the HF reference order: l2norm → multiply by scale → enter recurrence.
        float y_d = 0.0;
        for (uint p = 0; p < kdim; p++)
        {
            float qp = linear_q[(t * linear_num_v_heads + h) * kdim + p];
            y_d += recurrent_state[S_base + p * vdim + d] * qp;
        }
        linear_y[(t * linear_num_v_heads + h) * vdim + d] = y_d;
    }
}

// RMSNormGated: per-(token,head) RMSNorm with a gate from z.
// y' = silu(z) * (y / rms(y)) * gamma
// gamma shape [head_v_dim], applied per element.
// Input/output: linear_y (in/out reuses), z from linear_z.
#pragma kernel RMSNormGated
[numthreads(256, 1, 1)]
void RMSNormGated(uint3 id : SV_DispatchThreadID)
{
    uint vec = id.x;
    uint total_vecs = sequence_length_q * linear_num_v_heads;
    if (vec >= total_vecs) return;

    uint l = vec / linear_num_v_heads;
    uint h = vec % linear_num_v_heads;
    uint y_base = (l * linear_num_v_heads + h) * linear_head_v_dim;
    uint z_base = l * linear_value_dim + h * linear_head_v_dim;

    float sum_sq = 0.0;
    for (uint i = 0; i < linear_head_v_dim; i++)
    {
        float v = linear_y[y_base + i];
        sum_sq += v * v;
    }
    float rms = rsqrt(sum_sq / (float)linear_head_v_dim + norm_eps);

    for (uint i = 0; i < linear_head_v_dim; i++)
    {
        float zi = linear_z[z_base + i];
        float yi = linear_y[y_base + i];
        linear_y_norm[y_base + i] = silu(zi) * (yi * rms) * readH(norm_gamma, i);
    }
}

// LinearOutProj: linear_y_norm[seq, value_dim] * W_outProj^T[hidden, value_dim] -> O[seq, hidden]
// (Note: linear_y_norm shares storage layout with [seq, num_v_heads, head_v_dim] which is
//  contiguous and equals [seq, value_dim].)
#pragma kernel LinearOutProj
[numthreads(1, 4, 32)]
void LinearOutProj(uint3 id : SV_DispatchThreadID)
{
    uint b = id.x; uint l = id.y; uint e = id.z;
    if (b >= batch_size || l >= sequence_length_q || e >= embedding_dim) return;

    float sum = 0.0;
    uint y_base = (b * sequence_length_q + l) * linear_value_dim;
    for (uint k = 0; k < linear_value_dim; k++)
        sum += linear_y_norm[y_base + k] * readH(W_outProj, e * linear_value_dim + k);
    O[(b * sequence_length_q + l) * embedding_dim + e] = sum;
}


// ================================ MLP (SwiGLU) =================================
#pragma kernel GateUp
[numthreads(64, 8, 1)]
void GateUp(uint3 id : SV_DispatchThreadID)
{
    uint i_idx = id.x; uint l_idx = id.y; uint b_idx = id.z;
    if (i_idx >= intermediate_size || l_idx >= seq_len || b_idx >= batch_size) return;

    uint H = hidden_size;
    uint input_base = ((b_idx * seq_len) + l_idx) * H;

    float g = 0.0, u = 0.0;
    for (uint k = 0; k < H; k++)
    {
        float x = input[input_base + k];
        g += x * readH(mlp_gate_w, i_idx * H + k);
        u += x * readH(mlp_up_w,   i_idx * H + k);
    }

    uint out_idx = ((b_idx * seq_len) + l_idx) * intermediate_size + i_idx;
    if (activation_type == 0) intermediate[out_idx] = silu(g) * u;
    else                      intermediate[out_idx] = gelu(g) * u;
}

#pragma kernel Down
[numthreads(64, 8, 1)]
void Down(uint3 id : SV_DispatchThreadID)
{
    uint h_idx = id.x; uint l_idx = id.y; uint b_idx = id.z;
    if (h_idx >= hidden_size || l_idx >= seq_len || b_idx >= batch_size) return;

    uint inter_base = ((b_idx * seq_len) + l_idx) * intermediate_size;

    float acc = 0.0;
    for (uint i = 0; i < intermediate_size; i++)
        acc += intermediate[inter_base + i] * readH(mlp_down_w, h_idx * intermediate_size + i);

    input[((b_idx * seq_len) + l_idx) * hidden_size + h_idx] = acc;
}

#pragma kernel GateUp1Vec
[numthreads(256, 1, 1)]
void GateUp1Vec(uint3 id : SV_DispatchThreadID)
{
    uint i_idx = id.x;
    if (i_idx >= intermediate_size) return;

    uint H = hidden_size;
    float g = 0.0, u = 0.0;
    for (uint k = 0; k < H; k++)
    {
        float x = input[k];
        g += x * readH(mlp_gate_w, i_idx * H + k);
        u += x * readH(mlp_up_w,   i_idx * H + k);
    }
    if (activation_type == 0) intermediate[i_idx] = silu(g) * u;
    else                      intermediate[i_idx] = gelu(g) * u;
}

#pragma kernel Down1Vec
[numthreads(256, 1, 1)]
void Down1Vec(uint3 id : SV_DispatchThreadID)
{
    uint h_idx = id.x;
    if (h_idx >= hidden_size) return;

    float acc = 0.0;
    for (uint i = 0; i < intermediate_size; i++)
        acc += intermediate[i] * readH(mlp_down_w, h_idx * intermediate_size + i);
    input[h_idx] = acc;
}


// ================================ LM head + sampling ===========================
#pragma kernel LmHeadPredict
[numthreads(64, 8, 1)]
void LmHeadPredict(uint3 id : SV_DispatchThreadID)
{
    uint v = id.x; uint t = id.y;
    if (v >= vocab_size || t >= (batch_size * seq_len)) return;
    uint b = t / seq_len; uint l = t % seq_len;

    float sum = 0.0;
    uint in_base = ((b * seq_len) + l) * hidden_size;
    for (uint h = 0; h < hidden_size; h++)
        sum += lm_input[in_base + h] * readH(lm_weights, v * hidden_size + h);
    lm_output[((b * seq_len) + l) * vocab_size + v] = sum;
}

#pragma kernel LmHeadPredict1Vec
[numthreads(512, 1, 1)]
void LmHeadPredict1Vec(uint3 id : SV_DispatchThreadID)
{
    uint v = id.x;
    if (v >= vocab_size) return;
    float sum = 0.0;
    for (uint h = 0; h < hidden_size; h++)
        sum += lm_input[h] * readH(lm_weights, v * hidden_size + h);
    lm_output[v] = sum;
}

#pragma kernel ArgMax
[numthreads(1, 1, 1)]
void ArgMax(uint3 id : SV_DispatchThreadID)
{
    float best_val = logits_buf[0];
    uint  best_idx = 0;
    for (uint i = 1; i < vocab_size; i++)
    {
        float v = logits_buf[i];
        if (v > best_val) { best_val = v; best_idx = i; }
    }
    argmax_result[0] = best_idx;
}

#pragma kernel SampleToken
[numthreads(1, 1, 1)]
void SampleToken(uint3 id : SV_DispatchThreadID)
{
    float max_l = logits_buf[0];
    for (uint i = 1; i < vocab_size; i++)
        max_l = max(max_l, logits_buf[i]);

    float inv_temp = 1.0 / temperature;
    float sum_exp = 0.0;
    for (uint i = 0; i < vocab_size; i++)
    {
        float e = exp((logits_buf[i] - max_l) * inv_temp);
        probs_buf[i] = e;
        sum_exp += e;
    }
    float inv_sum = 1.0 / max(sum_exp, 1e-12);
    for (uint i = 0; i < vocab_size; i++)
        probs_buf[i] *= inv_sum;

    float max_prob = 0.0;
    for (uint i = 0; i < vocab_size; i++)
        max_prob = max(max_prob, probs_buf[i]);

    uint cand_count = 0;
    if (min_p_val > 0.0)
    {
        float min_thresh = max_prob * min_p_val;
        for (uint i = 0; i < vocab_size; i++)
        { if (probs_buf[i] >= min_thresh) cand_count++; else probs_buf[i] = 0.0; }
    }
    else
    {
        for (uint i = 0; i < vocab_size; i++)
            if (probs_buf[i] > 0.0) cand_count++;
    }

    if (cand_count == 0)
    {
        float best = logits_buf[0]; uint bi = 0;
        for (uint i = 1; i < vocab_size; i++) { float v = logits_buf[i]; if (v > best) { best = v; bi = i; } }
        argmax_result[0] = bi; return;
    }

    if (top_k_val > 0 && (uint)top_k_val < cand_count)
    {
        for (int k = 0; k < top_k_val; k++)
        {
            float best = -1.0; uint best_idx = 0;
            for (uint i = 0; i < vocab_size; i++)
            { if (probs_buf[i] > best) { best = probs_buf[i]; best_idx = i; } }
            probs_buf[best_idx] = -probs_buf[best_idx];
        }
        for (uint i = 0; i < vocab_size; i++)
            probs_buf[i] = (probs_buf[i] < 0.0) ? -probs_buf[i] : 0.0;
    }

    if (top_p_val < 1.0)
    {
        float cum = 0.0;
        while (cum < top_p_val)
        {
            float best = 0.0; uint best_idx = 0;
            for (uint i = 0; i < vocab_size; i++)
            { if (probs_buf[i] > best) { best = probs_buf[i]; best_idx = i; } }
            if (best <= 0.0) break;
            cum += best;
            probs_buf[best_idx] = -best;
        }
        for (uint i = 0; i < vocab_size; i++)
            probs_buf[i] = (probs_buf[i] < 0.0) ? -probs_buf[i] : 0.0;
    }

    float new_sum = 0.0;
    for (uint i = 0; i < vocab_size; i++) new_sum += probs_buf[i];
    if (new_sum <= 0.0)
    {
        float best = logits_buf[0]; uint bi = 0;
        for (uint i = 1; i < vocab_size; i++) { float v = logits_buf[i]; if (v > best) { best = v; bi = i; } }
        argmax_result[0] = bi; return;
    }
    float inv_new = 1.0 / new_sum;
    for (uint i = 0; i < vocab_size; i++) probs_buf[i] *= inv_new;

    float r = runif();
    float cdf = 0.0;
    uint sampled = 0;
    for (uint i = 0; i < vocab_size; i++)
    {
        cdf += probs_buf[i];
        if (cdf >= r) { sampled = i; break; }
    }
    argmax_result[0] = sampled;
}

// Applies repetition + presence penalty in place to the logits, for tokens already generated this
// sequence. Run once over the vocab before ArgMax/SampleToken. Both penalties no-op at their defaults
// (repetition_penalty=1.0, presence_penalty=0.0), so this is harmless when disabled.
#pragma kernel ApplyRepetitionPresencePenalty
[numthreads(256, 1, 1)]
void ApplyRepetitionPresencePenalty(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= vocab_size) return;
    if (token_seen[i] == 0u) return;
    float l = logits_buf[i];
    l = (l > 0.0) ? (l / repetition_penalty) : (l * repetition_penalty); // CTRL/HF repetition penalty
    l -= presence_penalty;                                               // OpenAI/vLLM presence penalty
    logits_buf[i] = l;
}

// Marks the just-sampled token (in argmax_result[0]) as seen so it is penalized on later steps.
#pragma kernel MarkSampledTokenSeen
[numthreads(1, 1, 1)]
void MarkSampledTokenSeen(uint3 id : SV_DispatchThreadID)
{
    token_seen[argmax_result[0]] += 1u;
}

// Clears the per-token occurrence counts (new sequence / cache reset).
#pragma kernel ZeroTokenSeen
[numthreads(256, 1, 1)]
void ZeroTokenSeen(uint3 id : SV_DispatchThreadID)
{
    uint i = id.x;
    if (i >= vocab_size) return;
    token_seen[i] = 0u;
}


// ================================ Buffer ops ===================================
#pragma kernel ZeroBuffer
[numthreads(256, 1, 1)]
void ZeroBuffer(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= buffer_size) return;
    buf_a[id.x] = 0.0;
}

#pragma kernel CopyBuffer
[numthreads(256, 1, 1)]
void CopyBuffer(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= buffer_size) return;
    buf_a[id.x] = buf_b[id.x];
}

#pragma kernel CopySlice
[numthreads(256, 1, 1)]
void CopySlice(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= buffer_size) return;
    buf_a[id.x] = buf_b[copy_src_offset + id.x];
}

#pragma kernel AddResidual
[numthreads(256, 1, 1)]
void AddResidual(uint3 id : SV_DispatchThreadID)
{
    if (id.x >= buffer_size) return;
    buf_a[id.x] += buf_b[id.x];
}
